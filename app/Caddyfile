:80 {
    root * /usr/share/caddy

    # API handlers primeiro (prioridade máxima)
    handle /api/* {
        reverse_proxy backend:3000
    }

    handle /images/* {
        reverse_proxy backend:3000
    }

    # Static files + SPA fallback (só para rotas frontend)
    handle {
        file_server
        try_files {path} /index.html
    }

    # Logging para debug
    log {
        output stdout
    }
}
