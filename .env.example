# ===========================================
# Marcio Natural - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# IMPORTANTE: Nunca comite o arquivo .env no Git!

# ===========================================
# Backend
# ===========================================

# Chave secreta para JWT (use uma string longa e aleatória)
# Gere uma com: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui

# ===========================================
# Frontend
# ===========================================

# URL da API (para o frontend saber onde conectar)
# Em produção, geralmente é a mesma URL do servidor
VITE_API_URL=http://localhost

# ===========================================
# Docker
# ===========================================

# Porta do frontend (padrão: 80)
FRONTEND_PORT=80

# ===========================================
# Produção
# ===========================================

# Defina como 'production' em produção
NODE_ENV=production
